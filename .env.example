# CostGuard Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# API Keys (Required for proxy functionality)
# =============================================================================

# OpenAI API Key - Get from https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key - Get from https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# OpenRouter API Key - Get from https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your-openrouter-key-here

# =============================================================================
# Server Configuration
# =============================================================================

# Host to bind the server (default: 127.0.0.1)
COSTGUARD_HOST=127.0.0.1

# Port to run the server on (default: 8000)
COSTGUARD_PORT=8000

# Base URL for the server
COSTGUARD_BASE_URL=http://127.0.0.1:8000

# =============================================================================
# Database Configuration
# =============================================================================

# Path to SQLite database (default: ~/.costguard/costguard.db)
# COSTGUARD_DB_PATH=~/.costguard/costguard.db

# =============================================================================
# Budget Limits (in USD)
# =============================================================================

# Maximum spend per session
COSTGUARD_SESSION_LIMIT=10.00

# Maximum spend per hour
COSTGUARD_HOUR_LIMIT=50.00

# Maximum spend per day
COSTGUARD_DAY_LIMIT=200.00

# Maximum spend per project
COSTGUARD_PROJECT_LIMIT=1000.00

# =============================================================================
# Safe Mode Configuration
# =============================================================================

# Cost threshold for safe mode confirmation (requests above this require explicit approval)
COSTGUARD_SAFE_MODE_THRESHOLD=5.00

# =============================================================================
# Alert Configuration
# =============================================================================

# Alert channels (comma-separated: console,webhook,file)
COSTGUARD_ALERT_CHANNELS=console

# Webhook URL for alerts (required if webhook channel is enabled)
# COSTGUARD_WEBHOOK_URL=https://your-webhook-url.com/alerts

# =============================================================================
# Dashboard Configuration
# =============================================================================

# WebSocket URL for dashboard
COSTGUARD_DASHBOARD_WS_URL=ws://127.0.0.1:8000/v1/dashboard/ws

# Dashboard refresh interval in seconds
COSTGUARD_DASHBOARD_REFRESH_INTERVAL=1.0

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
COSTGUARD_LOG_LEVEL=INFO

# Log file path (optional, defaults to console)
# COSTGUARD_LOG_FILE=~/.costguard/costguard.log

# =============================================================================
# Example Usage
# =============================================================================

# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. Edit .env and add your API keys
#
# 3. Start the server:
#    costguard server
#
# 4. Configure your application to use the proxy:
#    export OPENAI_BASE_URL=http://127.0.0.1:8000/v1
#    export OPENAI_API_KEY=your-openai-key
#
# 5. Run the dashboard (in another terminal):
#    costguard dashboard
